{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "outDir": "../../dist/client",
        "emitDeclarationOnly": false,
        "rewriteRelativeImportExtensions": true,
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ESNext"
        ],
        "paths": {
            "@components/*": [
                "../web/components/client/*"
            ],
            "@mods/*": [
                "./modules/*"
            ],
            "@styles/*": [
                "../web/styles/*"
            ]
        }
    }
}