{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Watch All",
            "dependsOn": [
                "Watch"
            ],
            "runOptions": {
                "runOn": "folderOpen"
            }
        },
        {
            "label": "Generate Database",
            "type": "shell",
            "command": "bun generate::database"
        },
        {
            "label": "Port",
            "type": "shell",
            "command": "source .env && ngrok http 3000"
        },
        {
            "label": "Watch",
            "type": "shell",
            "command": "bun run watch"
        }
    ]
}