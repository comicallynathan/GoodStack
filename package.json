{
  "name": "cabin",
  "module": "src/app.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/webpack": "^4.3.3",
    "@types/bun": "latest",
    "autoprefixer": "^10.5.4",
    "postcss": "^8.5.19",
    "postcss-loader": "^8.2.1",
    "tailwindcss": "^4.3.3"
  },
  "peerDependencies": {
    "typescript": "^5",
    "@typescript-eslint/eslint-plugin": "^6.7.5",
    "@typescript-eslint/parser": "^6.7.5",
    "eslint": "^7.31.0"
  },
  "dependencies": {
    "@buckoroo/safe-path": "^1.0.0",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^26.1.1",
    "css-loader": "^7.1.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "kysely": "^0.29.4",
    "mysql2": "^3.23.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pug": "^3.0.4",
    "pug-loader": "^2.4.0",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.2",
    "webpack": "^5.108.4",
    "zod": "^4.4.3"
  },
  "scripts": {
    "build": "bun build src/engine/app.ts --outdir build/dist --target node",
    "compile": "bun build --compile src/engine/app.ts --outfile build/release/bin",
    "generate::database": "bunx kysely-codegen --out-file src/engine/types/Database.d.ts",
    "port": "ngrok http 3000",
    "start": "bun run compile && ./build/release/bin | bunx pino-pretty",
    "watch": "bunx tsx --watch src/engine/app.ts"
  }
